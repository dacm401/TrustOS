# ── Auth (REQUIRED in production) ──────────────────────────────────────────
JWT_SECRET=<your-strong-secret-min-32-chars>
AUTH_USERS=admin:changeme
JWT_ENABLED=true

# ── Database ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/smartrouter

# ── Model Providers ────────────────────────────────────────────────────────
OPENAI_API_KEY=<your-key>
OPENAI_BASE_URL=https://api.siliconflow.cn/v1
FAST_MODEL=Qwen/Qwen2.5-72B-Instruct
SLOW_MODEL=Qwen/Qwen2.5-72B-Instruct
COMPRESSOR_MODEL=Qwen/Qwen2.5-7B-Instruct

# ── Startup ────────────────────────────────────────────────────────────────
# Run this BEFORE `npm run dev` to check prerequisites:
#   npm run dev:check
#
# Expected output (all green = ready):
#   ✅ Database  connected (Xms)
#   ✅ Port 3001 available
#   ✅ Port 3000 available
#   Auth: N user(s) configured (or ⚠ dev fallback)
